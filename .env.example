# Скопируй этот файл в .env и заполни значения

# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Твой Telegram ID (узнать у @userinfobot). Это даст тебе доступ к админ-меню.
ADMIN_ID=123456789

# Реквизиты для оплаты — бот покажет их ученику и в напоминаниях об оплате.
# Для переноса строки используй \n, например:
# PAYMENT_DETAILS=Сбербанк: 1234 5678 9012 3456\nПолучатель: Екатерина Т.\nЦена урока: 1200 ₽
PAYMENT_DETAILS=Сбербанк/СБП: 1234 5678 9012 3456\nПолучатель: Екатерина Т.

# Часовой пояс для напоминаний (по умолчанию Москва)
TIMEZONE=Europe/Moscow

# ---------- Google Календарь (необязательно) ----------
# Оставь пустым — и бот работает как раньше, без календаря.
# Подробная инструкция по настройке — в файле НАСТРОЙКА_КАЛЕНДАРЯ.md
#
# Куда писать уроки: обычно это твой email от Google-аккаунта.
GOOGLE_CALENDAR_ID=
# Ключ сервисного аккаунта одной строкой (всё содержимое скачанного JSON-файла).
# Удобно для хостинга. Локально можно вместо этого положить файл service_account.json в папку бота.
GOOGLE_CREDENTIALS_JSON=
# Длительность урока в минутах (для размера события в календаре).
LESSON_DURATION_MIN=60
